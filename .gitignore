###############################################################################
# Active/materialized user config
#
# Keep config/_ngsflow/ tracked: that contains shipped templates, schemas,
# manifest, and helper script.
#
# Ignore working configs generated by config/bin/ngsflow.py in the source repo.
###############################################################################

config/runs/*
!config/runs/.gitkeep

config/samples/*
!config/samples/.gitkeep

config/profiles/assays/*
!config/profiles/assays/.gitkeep

config/profiles/protocols/*
!config/profiles/protocols/.gitkeep

config/profiles/tools/*
!config/profiles/tools/.gitkeep

config/profiles/genomes/*
!config/profiles/genomes/.gitkeep

# If config/config.yaml is a source-template entry point, keep it tracked.
# If ngsflow.py mutates it during local testing, uncomment this:
# config/config.yaml

