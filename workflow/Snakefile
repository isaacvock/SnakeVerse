from pathlib import Path
import sys

configfile: "config/config.yaml"

try:
    WORKFLOW_DIR = Path(workflow.basedir).resolve()
except AttributeError:
    WORKFLOW_DIR = Path("workflow").resolve()

sys.path.insert(0, str(WORKFLOW_DIR / "lib"))

from config import get_results_dir, resolve_config_from_mapping
from samples import (
    alignment_fastq_1,
    alignment_fastq_2,
    bam_qc_targets,
    bigwig_targets,
    filtered_bam_targets,
    fastqc_targets,
    load_samples,
    raw_bam_targets,
    sample_ids,
    transcriptome_bam_targets,
    trimmed_fastq_targets,
)
from refs import genome_slug
from validation import validate_resolved_config


RESOLVED_CONFIG = resolve_config_from_mapping(config)
config.update(RESOLVED_CONFIG)

RESULTS_DIR = get_results_dir(config)
PROJECT_ROOT = config["_ngsflow"]["project_root"]
SAMPLES = load_samples(config["samples"], config["assay"], PROJECT_ROOT)
SAMPLE_IDS = sample_ids(SAMPLES)
GENOME_SLUG = genome_slug(config)

VALIDATION_ERRORS, VALIDATION_WARNINGS = validate_resolved_config(config, SAMPLES)
if VALIDATION_ERRORS:
    raise ValueError(
        "SnakeVerse config validation failed:\n  - "
        + "\n  - ".join(VALIDATION_ERRORS)
    )
for warning in VALIDATION_WARNINGS:
    print(f"SnakeVerse warning: {warning}")


output_enabled = lambda name: bool(config.get("outputs", {}).get(name, False))
step_enabled = lambda name, default=True: bool(config.get("steps", {}).get(name, default))
trimming_for_alignment = lambda: step_enabled("trimming", False)

raw_bam_path = lambda sample: f"{RESULTS_DIR}/bam/raw/{sample}.bam"
raw_bai_path = lambda sample: f"{RESULTS_DIR}/bam/raw/{sample}.bam.bai"
markdup_bam_path = lambda sample: f"{RESULTS_DIR}/bam/markdup/{sample}.bam"
markdup_bai_path = lambda sample: f"{RESULTS_DIR}/bam/markdup/{sample}.bam.bai"
filtered_bam_path = lambda sample: f"{RESULTS_DIR}/bam/filtered/{sample}.bam"
filtered_bai_path = lambda sample: f"{RESULTS_DIR}/bam/filtered/{sample}.bam.bai"
pre_filter_bam_path = lambda sample: (
    markdup_bam_path(sample) if step_enabled("mark_duplicates", False) else raw_bam_path(sample)
)
pre_filter_bai_path = lambda sample: (
    markdup_bai_path(sample) if step_enabled("mark_duplicates", False) else raw_bai_path(sample)
)
final_bam_path = lambda sample: (
    filtered_bam_path(sample) if step_enabled("bam_filter", True) else raw_bam_path(sample)
)
final_bai_path = lambda sample: (
    filtered_bai_path(sample) if step_enabled("bam_filter", True) else raw_bai_path(sample)
)

alignment_r1 = lambda wildcards: alignment_fastq_1(
    SAMPLES, wildcards.sample, RESULTS_DIR, trimming_for_alignment()
)
alignment_r2 = lambda wildcards: alignment_fastq_2(
    SAMPLES, wildcards.sample, RESULTS_DIR, trimming_for_alignment()
)


ASSAY_TARGETS = []
MULTIQC_INPUTS = []


rule all:
    input:
        lambda wildcards: ASSAY_TARGETS


include: str(WORKFLOW_DIR / "rules" / "common" / "fastq_qc.smk")

if step_enabled("trimming", False):
    include: str(WORKFLOW_DIR / "rules" / "common" / "trimming.smk")

ALIGNER = config.get("alignment", {}).get("tool")
if ALIGNER == "bowtie2":
    include: str(WORKFLOW_DIR / "rules" / "common" / "index_bowtie2.smk")
    include: str(WORKFLOW_DIR / "rules" / "common" / "align_bowtie2.smk")
elif ALIGNER == "star":
    include: str(WORKFLOW_DIR / "rules" / "common" / "index_star.smk")
    include: str(WORKFLOW_DIR / "rules" / "common" / "align_star.smk")
elif ALIGNER == "bwa_mem2":
    include: str(WORKFLOW_DIR / "rules" / "common" / "index_bwa_mem2.smk")
    include: str(WORKFLOW_DIR / "rules" / "common" / "align_bwa_mem2.smk")
else:
    raise ValueError(f"Unsupported or missing alignment.tool: {ALIGNER}")

include: str(WORKFLOW_DIR / "rules" / "common" / "bam_filter.smk")
include: str(WORKFLOW_DIR / "rules" / "common" / "mark_duplicates.smk")
include: str(WORKFLOW_DIR / "rules" / "common" / "bam_qc.smk")
include: str(WORKFLOW_DIR / "rules" / "common" / "coverage.smk")
include: str(WORKFLOW_DIR / "rules" / "common" / "multiqc.smk")

if config["assay"] == "generic":
    include: str(WORKFLOW_DIR / "rules" / "assays" / "generic.smk")
elif config["assay"] == "rnaseq":
    include: str(WORKFLOW_DIR / "rules" / "assays" / "rnaseq.smk")
elif config["assay"] == "atacseq":
    include: str(WORKFLOW_DIR / "rules" / "assays" / "atacseq.smk")
else:
    raise ValueError(f"Unsupported assay: {config['assay']}")
